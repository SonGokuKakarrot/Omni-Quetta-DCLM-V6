{
  "manifest_version": 3,
  "name": "Nocturnal Omni - Mic Maximizer Edition",
  "version": "2.1",
  "description": "Stylish Discord enhancer with Mic Maximizer audio controls",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://discord.com/*"
      ],
      "js": [
        "injector.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
